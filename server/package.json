{
  "name": "final-project-server",
  "version": "1.0.0",
  "description": "Backend server with Node.js, Express, MongoDB, and JWT",
  "main": "dist/index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:prod": "cross-env NODE_ENV=production node dist/index.js",
    "start:dev": "cross-env NODE_ENV=development node dist/index.js",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "dev:prod": "cross-env NODE_ENV=production tsx watch src/index.ts",
    "build": "tsc",
    "build:prod": "cross-env NODE_ENV=production tsc",
    "test": "jest",
    "seed": "cross-env NODE_ENV=development tsx src/scripts/seed.ts",
    "seed:fresh": "cross-env NODE_ENV=development tsx src/scripts/seed.ts --clear",
    "seed:force": "cross-env NODE_ENV=development tsx src/scripts/seed.ts --force",
    "seed:full": "cross-env NODE_ENV=development node src/scripts/seedFull.js",
    "db:reset": "cross-env NODE_ENV=development tsx src/scripts/seed.ts --clear --force"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "fs-extra": "^11.3.3",
    "helmet": "^7.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "react-toastify": "^11.0.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.4",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
